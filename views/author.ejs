<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/main.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <title>Portfolio</title>
</head>

<body>
    <div class="frame">
        <div class="main_frame">
            <div class="left_frame">
                <div class="left_1">
                    <div class="left_1_1">
                        <img src="images/Profile.svg" >
                    </div>
                    <div class="left_1_2"><%=user.name%></div>
                    <div class="left_1_3"><%=user.profession%></div>
                    <div class="left_icons">
                     <a href="" class="link_href">
                        <div class="icon">
                            <img src="icon/Icons-facebook.svg" alt="">
                        </div>
                     </a>
                     <a href="" class="link_href">
                        <div class="icon">
                            <img src="icon/Icons-instagram.svg" alt="">
                        </div>
                     </a>
                     <a href="" class="link_href">
                        <div class="icon">
                            <img src="icon/Icons-twitter.svg" alt="">
                        </div>
                     </a>
                     <a href="" class="link_href">
                        <div class="icon">
                            <img src="icon/Icons-linkedin.svg" alt="">
                        </div>
                     </a>
                     <a href="" class="link_href">
                        <div class="icon">
                            <img src="icon/Icons-Youtube.svg" alt="">
                        </div>
                     </a>
                     <a href="" class="link_href">
                        <div class="icon">
                            <img src="icon/Icons-dribbble.svg" alt="">
                        </div>
                     </a>
                    </div>
                </div>
                <div class="marginer"></div>
                <!-- 2-container -->
                <div class="left_2">
                    <div class="information">
                        <div class="age">Age:</div>
                        <div><%=user.age%></div>
                    </div>
                    <div class="information">
                        <div class="age_2">Residence:</div>
                        <div><%=user.residence%></div>
                    </div>
                    <div class="information">
                        <div class="age_3">Freelance:</div>
                        <div style="color: rgb(2, 147, 69);">Available</div>
                    </div>
                    <div class="information">
                        <div class="age_4">Address:</div>
                        <div><%=user.adress%></div>
                </div>
                    <!-- 2-container end -->

            </div>
            <div class="marginer"></div>
                <div class="left_3">
                    <div class="language">
                        <span>Languages</span>
                    </div>
                    <div class="lang_info">
                        <div class="lang">Uzbek</div>
                        <div class="foiz">100%</div>
                    </div>
                     <div class="box_border">
                        <div class="border_1"></div>
                     </div>
                    <div class="lang_info">
                        <div class="lang">Korean</div>
                        <div class="foiz">80%</div>
                    </div>
                     <div class="box_border">
                        <div class="border_2" style="width: 80%"></div>
                     </div>
                    <div class="lang_info">
                        <div class="lang">English</div>
                        <div class="foiz">60%</div>
                    </div>
                     <div class="box_border">
                        <div class="border_3"  style="width: 60%"></div>
                     </div>
                
                </div>
                <div class="marginer"></div>
                <div class="left_4"></div>
                <div class="marginer"></div>
                <div class="left_5"></div>
                <div class="marginer"></div>
        </div>
        <div class="midd_frame"></div>
            <div class="right_frame"></div>
    </div>   
</body>
</html>